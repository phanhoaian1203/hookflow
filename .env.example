# =============================================================================
# HookFlow — Environment Configuration Template
# Copy this file to '.env' and modify the values for your environment.
# =============================================================================

# --- General ---
ASPNETCORE_ENVIRONMENT=Development

# --- Database (PostgreSQL) ---
POSTGRES_PORT=5432
POSTGRES_DB=hookflow
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_db_password_here

# --- Backend API ---
API_PORT=5000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175

# --- Security (JWT) ---
# CRITICAL: Change this secret in production! Must be at least 256 bits (32 characters) long.
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long_change_me
JWT_ISSUER=HookFlow
JWT_AUDIENCE=HookFlowUsers
JWT_ACCESS_EXPIRY=60
JWT_REFRESH_EXPIRY=7

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_BASE_URL=/api
